# ─── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.backend and fill in your values

# OpenRouter API Key (required for AI tutor - get from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Configuration
DATABASE_URL=file:./server/db.sqlite

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration (set to your Vercel frontend URL after deploying)
FRONTEND_URL=https://your-app.vercel.app

# WebSocket Configuration
WS_PORT=3001
