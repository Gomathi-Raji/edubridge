# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.frontend and fill in your values

# OpenRouter API Key (required for AI tutor - get from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Backend API URL (change to your Vercel backend URL after deploying)
VITE_API_URL=http://localhost:3001

# App info
VITE_APP_NAME=EduBridge
